{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orbit WASM Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "source", "capabilities", "config", "meta"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "mediaType": { "enum": ["article", "manga", "video", "audio"] },
    "source": { "const": "wasm" },
    "capabilities": {
      "type": "array",
      "contains": { "const": "feed" }
    },
    "config": {
      "type": "object",
      "required": ["channels", "wasm"],
      "properties": {
        "refreshInterval": { "type": "integer", "minimum": 60 },
        "userAgent": { "type": "string" },
        "defaultChannel": { "type": "string" },
        "executionMode": { "enum": ["wasm", "browser", "hybrid"] },
        "channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "route"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "route": { "type": "string" },
              "params": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "itemLimit": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "wasm": {
          "type": "object",
          "properties": {
            "entry": { "type": "string", "default": "plugin.wasm" },
            "timeoutMs": { "type": "integer", "minimum": 1000 },
            "maxMemoryMB": { "type": "integer", "minimum": 4 }
          }
        },
        "browser": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "fallbackOn": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "logoText": { "type": "string" },
        "logoImageUrl": { "type": "string" },
        "marketCategory": { "type": "string" },
        "categoryTag": { "type": "string" },
        "official": { "type": "boolean" }
      }
    }
  }
}
