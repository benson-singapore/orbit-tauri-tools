{
  "id": "juejin",
  "name": "掘金",
  "version": "1.0.0",
  "mediaType": "article",
  "source": "wasm",
  "capabilities": ["feed"],
  "config": {
    "refreshInterval": 1800,
    "userAgent": "",
    "defaultChannel": "trending",
    "executionMode": "wasm",
    "channels": [
      {
        "id": "trending",
        "label": "热榜",
        "route": "/juejin/trending"
      },
      {
        "id": "category-frontend",
        "label": "前端",
        "route": "/juejin/category/:category",
        "params": { "category": "frontend" }
      }
    ],
    "wasm": {
      "entry": "plugin.wasm",
      "timeoutMs": 120000,
      "maxMemoryMB": 64
    }
  },
  "meta": {
    "description": "掘金开发者社区热榜与分类推荐",
    "icon": "text",
    "color": "bg-blue-500",
    "logoText": "掘",
    "marketCategory": "blog",
    "categoryTag": "DEV",
    "official": true
  }
}
