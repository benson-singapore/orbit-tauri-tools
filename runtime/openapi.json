                  "description": {
                    "type": "string"
                  },
                  "feedUrl": {
                    "type": "string"
                  },
                  "icon": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "logoImageUrl": {
                    "type": "string"
                  },
                  "logoText": {
                    "type": "string"
                  },
                  "marketCategory": {
                    "type": "string"
                  },
                  "mediaType": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "refreshInterval": {
                    "type": "integer"
                  },
                  "source": {
                    "type": "string"
                  },
                  "userAgent": {
                    "type": "string"
                  }
