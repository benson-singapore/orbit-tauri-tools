# macOS 代码签名与公证配置
# 复制为 signing.env 后填入你的信息（signing.env 已加入 .gitignore，不会提交）
#
#   cp scripts/signing.env.example scripts/signing.env
#
# 查看本机可用签名证书：
#   security find-identity -v -p codesigning

# ── 代码签名（必填其一）────────────────────────────────────────────
# Developer ID Application 证书名称（推荐，用于对外分发）
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# 仅本地测试、无证书时可改为临时签名（不能公证、不能对外分发）：
# APPLE_SIGNING_IDENTITY="-"

# ── 公证（可选，对外分发建议开启）──────────────────────────────────
# 方式 A：Apple ID + 应用专用密码
# APPLE_ID="your@email.com"
# APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="XXXXXXXXXX"

# 方式 B：App Store Connect API Key
# APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# APPLE_API_KEY="XXXXXXXXXX"
# APPLE_API_KEY_PATH="$HOME/keys/AuthKey_XXXXXXXXXX.p8"

# 若 Apple ID 关联多个团队，需指定 provider short name：
# APPLE_PROVIDER_SHORT_NAME="YourTeamName"
