{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for Orbit Reader",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/orbit-runtime",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/orbit-runtime",
          "sidecar": true
        }
      ]
    }
  ]
}
