{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orbit",
  "version": "1.1.4",
  "identifier": "com.orbit.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash ../scripts/tauri-before-build.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "orbit",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/orbit-runtime"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "entitlements": "entitlements.plist"
    },
    "resources": {
      "binaries/plugins/": "plugins/"
    }
  }
}
